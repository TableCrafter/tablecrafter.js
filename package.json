{
  "name": "tablecrafter",
  "version": "2.0.0",
  "description": "Zero-dependency JavaScript data table with inline editing, advanced filtering, and mobile card view. Companion library to the TableCrafter WordPress plugin.",
  "main": "dist/tablecrafter.cjs.js",
  "module": "dist/tablecrafter.esm.mjs",
  "unpkg": "dist/tablecrafter.umd.min.js",
  "types": "src/tablecrafter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tablecrafter.esm.mjs",
      "require": "./dist/tablecrafter.cjs.js",
      "types": "./src/tablecrafter.d.ts"
    },
    "./dist/tablecrafter.css": "./dist/tablecrafter.css"
  },
  "files": [
    "dist",
    "src/tablecrafter.js",
    "src/tablecrafter.css",
    "src/tablecrafter.d.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.mjs && node scripts/copy-css.js",
    "build:watch": "rollup -c rollup.config.mjs --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "data-table",
    "table",
    "vanilla-js",
    "zero-dependency",
    "inline-editing",
    "filtering",
    "sorting",
    "csv",
    "datatable",
    "editable-table"
  ],
  "author": "Fahad Murtaza",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@testing-library/jest-dom": "^6.8.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.0.0",
    "rollup": "^4.60.2"
  }
}
